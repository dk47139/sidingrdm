0438\u043d\u0442\u0435\u0440\u0435\u0441\u043d\u044b\u0435 \u0444\u0430\u043a\u0442\u044b \u043e \u0436\u0438\u0437\u043d\u0438 \u0434\u043e\u0441\u0442\u043e\u0439\u043d\u044b\u0445 \u043b\u0438\u0447\u043d\u043e\u0441\u0442\u0435\u0439. \u0422\u0430\u043a\u0438\u043c \u043e\u0431\u0440\u0430\u0437\u043e\u043c, \u043a\u0430\u043d\u0430\u043b \u00ab\u0414\u043e\u043c\u0430\u0448\u043d\u0438\u0439\u00bb \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u0435\u0442 \u0437\u0440\u0438\u0442\u0435\u043b\u044f\u043c \u043d\u0430\u0441\u044b\u0449\u0435\u043d\u043d\u0443\u044e \u0438 \u0443\u0432\u043b\u0435\u043a\u0430\u0442\u0435\u043b\u044c\u043d\u0443\u044e \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0443 \u043d\u0430 \u043a\u0430\u0436\u0434\u044b\u0439 \u0447\u0430\u0441.<\/p>\n<h2>\u041f\u043e\u043f\u0443\u043b\u044f\u0440\u043d\u044b\u0435 \u0448\u043e\u0443 \u0438 \u0438\u0445 \u0432\u0435\u0434\u0443\u0449\u0438\u0435: \u043a\u0442\u043e \u0432 \u0446\u0435\u043d\u0442\u0440\u0435 \u0432\u043d\u0438\u043c\u0430\u043d\u0438\u044f?<\/h2>\n<p>\u0412 \u044d\u0444\u0438\u0440\u0435 \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u044b \u00ab\u0414\u043e\u043c\u0430\u0448\u043d\u0438\u0439\u00bb \u0441\u0435\u0433\u043e\u0434\u043d\u044f \u043c\u043e\u0436\u043d\u043e \u0443\u0432\u0438\u0434\u0435\u0442\u044c \u0440\u044f\u0434 \u044f\u0440\u043a\u0438\u0445 \u0448\u043e\u0443, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u0440\u0438\u0432\u043b\u0435\u043a\u0430\u044e\u0442 \u0432\u043d\u0438\u043c\u0430\u043d\u0438\u0435 \u0437\u0440\u0438\u0442\u0435\u043b\u0435\u0439 \u0440\u0430\u0437\u043d\u043e\u043e\u0431\u0440\u0430\u0437\u0438\u0435\u043c \u0444\u043e\u0440\u043c\u0430\u0442\u043e\u0432 \u0438 \u0443\u0432\u043b\u0435\u043a\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u043c \u043a\u043e\u043d\u0442\u0435\u043d\u0442\u043e\u043c. \u041a\u0430\u0436\u0434\u043e\u0435 \u0448\u043e\u0443 \u0438\u043c\u0435\u0435\u0442 \u0441\u0432\u043e\u0435\u0433\u043e \u0443\u043d\u0438\u043a\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u0432\u0435\u0434\u0443\u0449\u0435\u0433\u043e, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0434\u0435\u043b\u0430\u0435\u0442 \u0435\u0433\u043e \u043e\u0441\u043e\u0431\u0435\u043d\u043d\u043e \u0437\u0430\u043f\u043e\u043c\u0438\u043d\u0430\u044e\u0449\u0438\u043c\u0441\u044f.<\/p>\n<h3>\u0428\u043e\u0443 \u00ab\u0421\u0435\u043a\u0440\u0435\u0442\u044b \u043d\u0430 \u043a\u0443\u0445\u043d\u0435\u00bb<\/h3>\n<p>\u0412\u0435\u0434\u0443\u0449\u0430\u044f \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u044b, \u0438\u0437\u0432\u0435\u0441\u0442\u043d\u0430\u044f \u0448\u0435\u0444-\u043f\u043e\u0432\u0430\u0440 \u041d\u0430\u0442\u0430\u043b\u044c\u044f, \u0434\u0435\u043b\u0438\u0442\u0441\u044f \u0441\u0432\u043e\u0438\u043c\u0438 \u043a\u0443\u043b\u0438\u043d\u0430\u0440\u043d\u044b\u043c\u0438 \u0441\u0435\u043a\u0440\u0435\u0442\u0430\u043c\u0438. \u041e\u043d\u0430 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0443\u0435\u0442 \u0437\u0430\u0445\u0432\u0430\u0442\u044b\u0432\u0430\u044e\u0449\u0438\u0435 \u043a\u0443\u043b\u0438\u043d\u0430\u0440\u043d\u044b\u0435 \u043c\u0430\u0441\u0442\u0435\u0440-\u043a\u043b\u0430\u0441\u0441\u044b, \u0430 \u0442\u0430\u043a\u0436\u0435 \u043f\u0440\u0438\u0433\u043b\u0430\u0448\u0430\u0435\u0442 \u0438\u0437\u0432\u0435\u0441\u0442\u043d\u044b\u0445 \u0433\u043e\u0441\u0442\u0435\u0439 \u2013 \u0448\u0435\u0444\u043e\u0432 \u0438 \u043a\u0443\u043b\u0438\u043d\u0430\u0440\u043e\u0432, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u043e\u043c\u043e\u0433\u0430\u044e\u0442 \u0441\u043e\u0437\u0434\u0430\u0432\u0430\u0442\u044c \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0435 \u0431\u043b\u044e\u0434\u0430. \u0417\u0440\u0438\u0442\u0435\u043b\u0438 \u0446\u0435\u043d\u044f\u0442 \u0435\u0451 \u0441\u0442\u0440\u0430\u0441\u0442\u044c \u043a \u043a\u0443\u043b\u0438\u043d\u0430\u0440\u0438\u0438 \u0438 \u0443\u043c\u0435\u043d\u0438\u0435 \u0437\u0430\u0432\u0435\u0441\u0442\u0438 \u0440\u0430\u0437\u0433\u043e\u0432\u043e\u0440.<\/p>\n<h3>\u0422\u043e\u043a-\u0448\u043e\u0443 \u00ab\u0421\u0432\u0435\u0442\u043b\u044b\u0435 \u0433\u043e\u043b\u043e\u0432\u044b\u00bb<\/h3>\n<p>\u041d\u0435 \u043c\u0435\u043d\u0435\u0435 \u043f\u043e\u043f\u0443\u043b\u044f\u0440\u043d\u043e \u0442\u043e\u043a-\u0448\u043e\u0443, \u0433\u0434\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043d\u044b\u0439 \u0442\u0435\u043b\u0435\u0432\u0435\u0434\u0443\u0449\u0438\u0439 \u0418\u0433\u043e\u0440\u044c \u0441 \u043f\u043e\u043c\u043e\u0449\u044c\u044e \u0433\u043e\u0441\u0442\u0435\u0439 \u043e\u0431\u0441\u0443\u0436\u0434\u0430\u0435\u0442 \u0430\u043a\u0442\u0443\u0430\u043b\u044c\u043d\u044b\u0435 \u043e\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0435 \u0442\u0435\u043c\u044b. \u041a\u0430\u0436\u0434\u044b\u0439 \u0432\u044b\u043f\u0443\u0441\u043a \u043f\u043e\u0441\u0432\u044f\u0449\u0435\u043d \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u043d\u043e\u0439 \u0442\u0435\u043c\u0435 \u0438 \u0432\u043a\u043b\u044e\u0447\u0430\u0435\u0442 \u0432 \u0441\u0435\u0431\u044f \u0436\u0438\u0432\u0443\u044e \u0434\u0438\u0441\u043a\u0443\u0441\u0441\u0438\u044e. \u0417\u0440\u0438\u0442\u0435\u043b\u0438 \u0443\u0447\u0430\u0441\u0442\u0432\u0443\u044e\u0442 \u0447\u0435\u0440\u0435\u0437 \u0441\u043e\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0435 \u0441\u0435\u0442\u0438, \u0437\u0430\u0434\u0430\u0432\u0430\u044f \u0432\u043e\u043f\u0440\u043e\u0441\u044b \u0438 \u0434\u0435\u043b\u044f\u0441\u044c \u0441\u0432\u043e\u0438\u043c\u0438 \u043c\u043d\u0435\u043d\u0438\u044f\u043c\u0438.<\/p>\n<ul> \u0424\u043e\u0440\u043c\u0430\u0442 \u0432\u043a\u043b\u044e\u0447\u0430\u0435\u0442 \u0432\u0441\u0442\u0440\u0435\u0447\u0438 \u0441 \u044d\u043a\u0441\u043f\u0435\u0440\u0442\u0430\u043c\u0438 \u0438\u0437 \u0440\u0430\u0437\u043b\u0438\u0447\u043d\u044b\u0445 \u043e\u0431\u043b\u0430\u0441\u0442\u0435\u0439. \u0418\u0433\u043e\u0440\u044c \u0441\u043f\u043e\u0441\u043e\u0431\u0435\u043d \u0441\u043e\u0437\u0434\u0430\u0442\u044c \u0430\u0442\u043c\u043e\u0441\u0444\u0435\u0440\u0443 \u043a\u043e\u043c\u0444\u043e\u0440\u0442\u0430, \u0447\u0442\u043e \u043f\u043e\u043c\u043e\u0433\u0430\u0435\u0442 \u0433\u043e\u0441\u0442\u044f\u043c \u043e\u0442\u043a\u0440\u044b\u0442\u044c\u0441\u044f. \u0428\u043e\u0443 \u0430\u043a\u0442\u0438\u0432\u043d\u043e \u043f\u0440\u0438\u0432\u043b\u0435\u043a\u0430\u0435\u0442 \u043c\u043e\u043b\u043e\u0434\u0443\u044e \u0430\u0443\u0434\u0438\u0442\u043e\u0440\u0438\u044e \u0431\u043b\u0430\u0433\u043e\u0434\u0430\u0440\u044f \u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u043c \u0442\u0435\u043c\u0430\u043c. <\/ul>\n<p>\u0422\u0430\u043a\u0436\u0435 \u0432\u044b\u0434\u0435\u043b\u044f\u0435\u0442\u0441\u044f \u0448\u043e\u0443 \u00ab\u0422\u0430\u043b\u0430\u043d\u0442\u044b \u043d\u0430 \u0441\u0446\u0435\u043d\u0435\u00bb, \u0433\u0434\u0435 \u043e\u0431\u0449\u0435\u043f\u0440\u0438\u0437\u043d\u0430\u043d\u043d\u044b\u0439 \u043b\u044e\u0431\u0438\u043c\u0435\u0446 \u043f\u0443\u0431\u043b\u0438\u043a\u0438, \u043f\u0435\u0432\u0435\u0446 \u0438 \u0430\u043a\u0442\u0451\u0440 \u0410\u043b\u0435\u043a\u0441\u0435\u0439, \u043e\u0431\u043d\u0430\u0440\u0443\u0436\u0438\u0432\u0430\u0435\u0442 \u043d\u043e\u0432\u044b\u0435 \u0438\u043c\u0435\u043d\u0430 \u0432 \u043c\u0438\u0440\u0435 \u0438\u0441\u043a\u0443\u0441\u0441\u0442\u0432\u0430. \u041a\u0430\u0436\u0434\u044b\u0439 \u044d\u043f\u0438\u0437\u043e\u0434 \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u0435\u0442 \u0437\u0440\u0438\u0442\u0435\u043b\u044f\u043c \u043f\u043e\u0437\u043d\u0430\u043a\u043e\u043c\u0438\u0442\u044c\u0441\u044f \u0441 \u044f\u0440\u043a\u0438\u043c\u0438 \u0442\u0430\u043b\u0430\u043d\u0442\u0430\u043c\u0438, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0432\u044b\u0441\u0442\u0443\u043f\u0430\u044e\u0442