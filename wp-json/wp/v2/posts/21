u044f \u043a\u043e\u043d\u0442\u0435\u043d\u0442\u0430?<\/strong> \u0412 \u044d\u0442\u043e\u0439 \u0441\u0442\u0430\u0442\u044c\u0435 \u043c\u044b \u0440\u0430\u0441\u0441\u043c\u043e\u0442\u0440\u0438\u043c \u043b\u0443\u0447\u0448\u0438\u0435 \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u044b \u0434\u043b\u044f \u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440\u0430, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0441\u043c\u043e\u0433\u0443\u0442 \u0443\u0434\u043e\u0432\u043b\u0435\u0442\u0432\u043e\u0440\u0438\u0442\u044c \u0440\u0430\u0437\u043b\u0438\u0447\u043d\u044b\u0435 \u0432\u043a\u0443\u0441\u044b \u0438 \u043f\u0440\u0435\u0434\u043f\u043e\u0447\u0442\u0435\u043d\u0438\u044f.<\/p>\n<p>\u0422\u0435\u043b\u0435\u0432\u0438\u0434\u0435\u043d\u0438\u0435 \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u0435\u0442 \u043c\u043d\u043e\u0436\u0435\u0441\u0442\u0432\u043e \u0436\u0430\u043d\u0440\u043e\u0432: \u043e\u0442 \u0437\u0430\u0445\u0432\u0430\u0442\u044b\u0432\u0430\u044e\u0449\u0438\u0445 \u0434\u0440\u0430\u043c \u0434\u043e \u0432\u0435\u0441\u0435\u043b\u044b\u0445 \u043a\u043e\u043c\u0435\u0434\u0438\u0439. <strong>\u041a\u0430\u0436\u0434\u044b\u0439 \u0432\u0435\u0447\u0435\u0440 \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u043d\u043e\u0432\u044b\u0435 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u0438<\/strong> \u0434\u043b\u044f \u0442\u043e\u0433\u043e, \u0447\u0442\u043e\u0431\u044b \u043d\u0430\u0441\u043b\u0430\u0434\u0438\u0442\u044c\u0441\u044f \u0443\u044e\u0442\u043d\u044b\u043c \u0432\u0440\u0435\u043c\u044f\u043f\u0440\u0435\u043f\u0440\u043e\u0432\u043e\u0436\u0434\u0435\u043d\u0438\u0435\u043c \u0432\u043c\u0435\u0441\u0442\u0435 \u0441 \u0441\u0435\u043c\u044c\u0435\u0439 \u0438\u043b\u0438 \u043d\u0430\u0435\u0434\u0438\u043d\u0435 \u0441 \u0441\u043e\u0431\u043e\u0439. \u041c\u044b \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u0438\u043b\u0438 \u0434\u043b\u044f \u0432\u0430\u0441 \u0438\u0434\u0435\u0430\u043b\u044c\u043d\u044b\u0439 \u0433\u0438\u0434 \u043f\u043e \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0430\u043c, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0441\u043c\u043e\u0433\u0443\u0442 \u0441\u0434\u0435\u043b\u0430\u0442\u044c \u0432\u0430\u0448 \u0432\u0435\u0447\u0435\u0440 \u043d\u0435\u0437\u0430\u0431\u044b\u0432\u0430\u0435\u043c\u044b\u043c.<\/p>\n<p>\u041d\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043c\u043e \u043e\u0442 \u0442\u043e\u0433\u043e, \u0445\u043e\u0442\u0438\u0442\u0435 \u043b\u0438 \u0432\u044b \u043f\u043e\u0433\u0440\u0443\u0437\u0438\u0442\u044c\u0441\u044f \u0432 \u043c\u0438\u0440 \u0443\u0432\u043b\u0435\u043a\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u0445 \u0441\u0435\u0440\u0438\u0430\u043b\u043e\u0432, \u043f\u043e\u0441\u043c\u043e\u0442\u0440\u0435\u0442\u044c \u043d\u043e\u0432\u044b\u0439 \u0444\u0438\u043b\u044c\u043c \u0438\u043b\u0438 \u043d\u0430\u0441\u043b\u0430\u0434\u0438\u0442\u044c\u0441\u044f \u0440\u0430\u0437\u0432\u043b\u0435\u043a\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u043c\u0438 \u0448\u043e\u0443, \u043a\u0430\u0436\u0434\u044b\u0439 \u043d\u0430\u0439\u0434\u0435\u0442 \u0447\u0442\u043e-\u0442\u043e \u0438\u043d\u0442\u0435\u0440\u0435\u0441\u043d\u043e\u0435 \u0434\u043b\u044f \u0441\u0435\u0431\u044f. \u0414\u0430\u0432\u0430\u0439\u0442\u0435 \u0432\u043c\u0435\u0441\u0442\u0435 \u0440\u0430\u0437\u0431\u0435\u0440\u0435\u043c\u0441\u044f, \u0447\u0442\u043e \u0436\u0435 \u043f\u0440\u0435\u043a\u0440\u0430\u0441\u043d\u043e\u0433\u043e \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u0435\u0442 \u0442\u0435\u043b\u0435\u0432\u0438\u0437\u0438\u043e\u043d\u043d\u044b\u0439 \u044d\u0444\u0438\u0440 \u0441\u0435\u0433\u043e\u0434\u043d\u044f \u0432\u0435\u0447\u0435\u0440\u043e\u043c.<\/p>\n<h2>\u041b\u0443\u0447\u0448\u0438\u0435 \u043d\u043e\u0432\u044b\u0435 \u0441\u0435\u0440\u0438\u0430\u043b\u044b \u0434\u043b\u044f \u0432\u0435\u0447\u0435\u0440\u043d\u0435\u0433\u043e \u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440\u0430<\/h2>\n<h3>\u0421\u0443\u043f\u0435\u0440\u0433\u0435\u0440\u043e\u0438 \u0438 \u0444\u0430\u043d\u0442\u0430\u0441\u0442\u0438\u043a\u0430<\/h3>\n<p>\u0414\u043b\u044f \u043f\u043e\u043a\u043b\u043e\u043d\u043d\u0438\u043a\u043e\u0432 \u0444\u0430\u043d\u0442\u0430\u0441\u0442\u0438\u043a\u0438 \u0441\u0442\u043e\u0438\u0442 \u0432\u044b\u0434\u0435\u043b\u0438\u0442\u044c &#8220;\u0413\u0430\u043b\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0443\u044e \u0437\u0430\u0449\u0438\u0442\u0443&#8221;, \u043d\u043e\u0432\u044b\u0439 \u0441\u0443\u043f\u0435\u0440\u0433\u0435\u0440\u043e\u0439\u0441\u043a\u0438\u0439 \u0441\u0435\u0440\u0438\u0430\u043b, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0441\u043e\u0447\u0435\u0442\u0430\u0435\u0442 \u0432 \u0441\u0435\u0431\u0435 \u044d\u043b\u0435\u043c\u0435\u043d\u0442\u044b \u043a\u043e\u043c\u0435\u0434\u0438\u0438 \u0438 \u0434\u0440\u0430\u043c\u044b. \u0413\u043b\u0430\u0432\u043d\u044b\u0435 \u0433\u0435\u0440\u043e\u0438 \u2013 \u043a\u043e\u043c\u0430\u043d\u0434\u0430 \u0440\u0430\u0437\u043d\u043e\u0448\u0435\u0440\u0441\u0442\u043d\u044b\u0445 \u0438\u043d\u0434\u0438\u0432\u0438\u0434\u0443\u0443\u043c\u043e\u0432 \u0441 \u0443\u043d\u0438\u043a\u0430\u043b\u044c\u043d\u044b\u043c\u0438 \u0441\u043f\u043e\u0441\u043e\u0431\u043d\u043e\u0441\u0442\u044f\u043c\u0438, \u0440\u0430\u0431\u043e\u0442\u0430\u044e\u0449\u0438\u0445 \u0432\u043c\u0435\u0441\u0442\u0435, \u0447\u0442\u043e\u0431\u044b \u0441\u043f\u0430\u0441\u0430\u0442\u044c \u043c\u0438\u0440 \u043e\u0442 \u0440\u0430\u0437\u043d\u044b\u0445 \u0443\u0433\u0440\u043e\u0437. \u042f\u0440\u043a\u0438\u0435 \u043f\u0435\u0440\u0441\u043e\u043d\u0430\u0436\u0438 \u0438 \u043d\u0435\u043e\u0436\u0438\u0434\u0430\u043d\u043d\u043e\u0435 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0441\u043e\u0431\u044b\u0442\u0438\u0439 \u0434\u0435\u043b\u0430\u044e\u0442 \u0435\u0433\u043e \u043e\u0442\u043b\u0438\u0447\u043d\u044b\u043c \u0432\u044b\u0431\u043e\u0440\u043e\u043c \u0434\u043b\u044f \u0432\u0441\u0435\u0439 \u0441\u0435\u043c\u044c\u0438.<\/p>\n<p>\u041d\u0435 \u043c\u0435\u043d\u0435\u0435 \u0438\u043d\u0442\u0435\u0440\u0435\u0441\u043d\u044b\u043c \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f &#8220;\u0422\u0430\u0439\u043d\u0430 \u0434\u0440\u0435\u0432\u043d\u0438\u0445&#8221;, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u043f\u0435\u0440\u0435\u043d\u043e\u0441\u0438\u0442 \u0437\u0440\u0438\u0442\u0435\u043b\u0435\u0439 \u0432 \u0437\u0430\u0433\u0430\u0434\u043e\u0447\u043d\u044b\u0439 \u043c\u0438\u0440 \u0438\u0441\u0442\u043e\u0440\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u0442\u0430\u0439\u043d \u0438 \u043f\u0440\u0438\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u0439. \u0418\u0441\u0442\u043e\u0440\u0438\u044f \u0441\u043e\u0441\u0440\u0435\u0434\u043e\u0442\u043e\u0447\u0435\u043d\u0430 \u043d\u0430 \u0430\u0440\u0445\u0435\u043e\u043b\u043e\u0433\u0430\u0445, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0441\u0442\u0430\u043b\u043a\u0438\u0432\u0430\u044e\u0442\u0441\u044f \u0441 \u043c\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u043c\u0438 \u0430\u0440\u0442\u0435\u0444\u0430\u043a\u0442\u0430\u043c\u0438 \u0438 \u043e\u0431\u0440\u0435\u0442\u0430\u044e\u0442 \u043d\u0435\u0432\u0435\u0440\u043e\u044f\u0442\u043d\u044b\u0435 \u0441\u043f\u043e\u0441\u043e\u0431\u043d\u043e\u0441\u0442\u0438. \u042d\u0442\u043e\u0442 \u0441\u0435\u0440\u0438\u0430\u043b \u043d\u0435 \u0442\u043e\u043b\u044c\u043a\u043e \u0440\u0430\u0437\u0432\u043b\u0435\u043a\u0430\u0435\u0442, \u043d\u043e \u0438 \u0437\u043d\u0430\u043a\u043e\u043c\u0438\u0442 \u0437\u0440\u0438\u0442\u0435\u043b\u0435\u0439 \u0441 \u043a\u0443\u043b\u044c\u0442\u0443\u0440\u043d\u044b\u043c\u0438 \u0438 \u0438\u0441\u0442\u043e\u0440\u0438\u0447\u0435\u0441\u043a\u0438\u043c\u0438 \u0430\u0441\u043f\u0435\u043a\u0442\u0430\u043c\u0438.<\/p>\n<h3>\u0414\u0440\u0430\u043c\u044b \u0438 \u043a\u043e\u043c\u0435\u0434\u0438\u0438<\/h3>\n<p>\u041d\u0435\u043b\u044c\u0437\u044f \u0437\u0430\u0431\u044b\u0432\u0430\u0442\u044c \u043e &#8220;\u041d\u0430\u0441\u043b\u0435\u0434\u043d\u0438\u043a\u0430\u0445&#8221;, \u0434\u0440\u0430\u043c\u0435\u0434\u0438, \u0440\u0430\u0441\u0441\u043a\u0430\u0437\u044b\u0432\u0430\u044e\u0449\u0435\u0439 \u043e \u0436\u0438\u0437\u043d\u0438 \u0431\u043e\u0433\u0430\u0442\u043e\u0439 \u0441\u0435\u043c\u044c\u0438, \u043e\u043a\u0443\u043d\u0443\u0432\u0448\u0435\u0439\u0441\u044f \u0432 \u0441\u043b\u043e\u0436\u043d\u044b\u0435 \u043e\u0442\u043d\u043e\u0448\u0435\u043d\u0438\u044f \u0438 \u0431\u043e\u0440\u044c\u0431\u0443 \u0437\u0430 \u043d\u0430\u0441\u043b\u0435\u0434\u0441\u0442\u0432\u043e. \u041a\u0430\u0436\u0434\u0430\u044f \u0441\u0435\u0440\u0438\u044f \u043d\u0430\u043f\u043e\u043b\u043d\u0435\u043d\u0430 \u0438\u043d\u0442\u0440\u0438\u0433\u0430\u043c\u0438 \u0438 \u043e\u0441\u0442\u0440\u043e\u0443\u043c\u043d\u044b\u043c \u044e\u043c\u043e\u0440\u043e\u043c, \u0432 \u0442\u043e \u0432\u0440\u0435\u043c\u044f \u043a\u0430\u043a \u0437\u0440\u0438\u0442\u0435\u043b\u0438 \u043f\u043e\u0433\u0440\u0443\u0436\u0430\u044e\u0442\u0441\u044f \u0432 \u044d\u043c\u043e\u0446\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u044b\u0435 \u0443\u043b\u043e\u0432\u043a\u0438 \u043f\u0435\u0440\u0441\u043e\u043d\u0430\u0436\u0435\u0439. \u042d\u0442\u043e \u0438\u0434\u0435\u0430\u043b\u044c\u043d\u044b\u0439 \u0441\u0435\u0440\u0438\u0430\u043b \u0434\u043b\u044f \u0442\u0435\u0445, \u043a\u0442\u043e \u0446\u0435\u043d\u0438\u0442 \u043c\u0443\u043b\u044c\u0442\u0438\u0436\u0430\u043d\u0440\u043e\u0432\u044b\u0435 \u0441\u044e\u0436\u0435\u0442\u044b.<\/p>\n<h2>\u0418\u043d\u0442\u0435\u0440\u0435\u0441\u043d\u044b\u0435 \u0444\u0438\u043b\u044c\u043c\u044b \u043d\u0430 \u0432\u0435\u0447\u0435\u0440: \u0447\u0442\u043e \u0432\u044b\u0431\u0438\u0440\u0430\u0435\u043c?<\/h2>\n<p><img src=\"\/wp-content\/images\/televizionnie-programmi-chto-posmotret-segodnya-vecherom.jpg\" alt=\"\u0438\u043d\u0442\u0435\u0440\u0435\u0441\u043d\u044b\u0435 \u0444\u0438\u043b\u044c\u043c\u044b \u043d\u0430 \u0432\u0435\u0447\u0435\u0440: \u0447\u0442\u043e \u0432\u044b\u0431\u0438\u0440\u0430\u0435\u043c?\" class=\"\"\/><\/p>\n<p>\u0414\u043b\u044f \u0443\u044e\u0442\u043d\u043e\u0433\u043e \u0432\u0435\u0447\u0435\u0440\u0430 \u0441 \u043b\u044e\u0431\u0438\u043c\u044b\u043c\u0438 \u0444\u0438\u043b\u044c\u043c\u0430\u043c\u0438 \u0432\u0430\u0436\u043d\u043e \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u043e \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u0436\u0430\u043d\u0440. \u041f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u0435\u043c \u0432\u0430\u043c \u043c\u0430\u0441\u0441\u0438\u0432 \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0430\u0446\u0438\u0439, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u043e\u043c\u043e\u0433\u0443\u0442 \u0432\u0430\u043c \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0438\u0442\u044c\u0441\u044f \u0441 \u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440\u043e\u043c. \u0421\u043c\u043e\u0442\u0440\u0438\u0442\u0435, \u0447\u0442\u043e \u0441\u0435\u0433\u043e\u0434\u043d\u044f \u043c\u043e\u0436\u0435\u0442 \u043f\u043e\u0434\u043d\u044f\u0442\u044c \u0432\u0430\u043c \u043d\u0430\u0441\u0442\u0440\u043e\u0435\u043d\u0438\u0435 \u0438\u043b\u0438 \u0432\u044b\u0437\u0432\u0430\u0442\u044c \u0437\u0430\u0434\u0443\u043c\u0447\u0438\u0432\u043e\u0441\u0442\u044c.<\/p>\n<h3>\u041a\u043e\u043c\u0435\u0434\u0438\u0438 \u0434\u043b\u044f \u0445\u043e\u0440\u043e\u0448\u0435\u0433\u043e \u043d\u0430\u0441\u0442\u0440\u043e\u0435\u043d\u0438\u044f<\/h3>\n<p>\u0415\u0441\u043b\u0438 \u0432\u044b \u0445\u043e\u0442\u0438\u0442\u0435 \u0440\u0430\u0441\u0441\u043b\u0430\u0431\u0438\u0442\u044c\u0441\u044f \u0438 \u043f\u043e\u0441\u043c\u0435\u044f\u0442\u044c\u0441\u044f, \u043a\u043e\u043c\u0435\u0434\u0438\u0439\u043d\u044b\u0435 \u0444\u0438\u043b\u044c\u043c\u044b \u2013 \u0438\u0434\u0435\u0430\u043b\u044c\u043d\u044b\u0439 \u0432\u044b\u0431\u043e\u0440. \u0412\u043e\u0442 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u043a\u043b\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u0438 \u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u0445 \u043a\u043e\u043c\u0435\u0434\u0438\u0439, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0441\u0442\u043e\u0438\u0442 \u043f\u043e\u0441\u043c\u043e\u0442\u0440\u0435\u0442\u044c:<\/p>\n<ul> \u00ab\u0421\u0432\u0430\u0434\u0435\u0431\u043d\u044b\u0439 \u0443\u0433\u0430\u0440\u00bb \u2013 \u0432\u0435\u0441\u0451\u043b\u044b\u0439 \u0444\u0438\u043b\u044c\u043c \u043e \u043d\u0435\u0443\u0434\u0430\u0447\u0430\u0445 \u043d\u0430 \u0441\u0432\u0430\u0434\u044c\u0431\u0435. \u00ab\u042d\u0442\u043e\u0442 \u043d\u0435\u043b\u043e\u0432\u043a\u0438\u0439 \u043c\u043e\u043c\u0435\u043d\u0442\u00bb \u2013 \u0441\u0432\u0435\u0436\u0430\u044f \u0440\u043e\u043c\u0430\u043d\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u043a\u043e\u043c\u0435\u0434\u0438\u044f \u0441 \u043d\u0435\u043e\u0436\u0438\u0434\u0430\u043d\u043d\u044b\u043c\u0438 \u043f\u043e\u0432\u043e\u0440\u043e\u0442\u0430\u043c\u0438. \u00ab\u0414\u0435\u043d\u044c \u0441\u0443\u0440\u043a\u0430\u00bb \u2013 \u043a\u0443\u043b\u044c\u0442\u043e\u0432\u0430\u044f \u043a\u043e\u043c\u0435\u0434\u0438\u044f \u043e \u043f\u043e\u0432\u0442\u043e\u0440\u044f\u044e\u0449\u0435\u043c\u0441\u044f \u0434\u043d\u0435. <\/ul>\n<h3>\u0414\u0440\u0430\u043c\u044b, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0437\u0430\u0441\u0442\u0430\u0432\u044f\u0442 \u0437\u0430\u0434\u0443\u043c\u0430\u0442\u044c\u0441\u044f<\/h3>\n<p>\u0414\u043b\u044f \u043b\u044e\u0431\u0438\u0442\u0435\u043b\u0435\u0439 \u0433\u043b\u0443\u0431\u043e\u043a\u0438\u0445 \u0441\u044e\u0436\u0435\u0442\u043e\u0432 \u0434\u0440\u0430\u043c\u0430 \u0441\u0442\u0430\u043d\u0435\u0442 \u043e\u0442\u043b\u0438\u0447\u043d\u044b\u043c \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u043e\u043c. \u042d\u0442\u0438 \u0444\u0438\u043b\u044c\u043c\u044b \u043f\u043e\u0433\u0440\u0443\u0436\u0430\u044e\u0442 \u0432 \u0430\u0442\u043c\u043e\u0441\u0444\u0435\u0440\u0443 \u0438 \u0432\u044b\u0437\u044b\u0432\u0430\u044e\u0442 \u043c\u043d\u043e\u0436\u0435\u0441\u0442\u0432\u043e \u044d\u043c\u043e\u0446\u0438\u0439:<\/p>\n<p> \u00ab\u0417\u0435\u043b\u0435\u043d\u0430\u044f \u043a\u043d\u0438\u0433\u0430\u00bb \u2013 \u0442\u0440\u043e\u0433\u0430\u0442\u0435\u043b\u044c\u043d\u0430\u044f \u0438\u0441\u0442\u043e\u0440\u0438\u044f \u0434\u0440\u0443\u0436\u0431\u044b \u0440\u0430\u0437\u043d\u044b\u0445 \u043b\u044e\u0434\u0435\u0439. \u00ab\u0411\u043e\u0439\u0446\u043e\u0432\u0441\u043a\u0438\u0439 \u043a\u043b\u0443\u0431\u00bb \u2013 \u043a\u0443\u043b\u044c\u0442\u043e\u0432\u044b\u0439 \u0444\u0438\u043b\u044c\u043c \u043e \u0432\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0435\u0439 \u0431\u043e\u0440\u044c\u0431\u0435 \u0438 \u043f\u043e\u0438\u0441\u043a\u0430\u0445 \u0441\u0435\u0431\u044f. \u00ab\u0421\u0438\u044f\u043d\u0438\u0435\u00bb \u2013 \u043a\u043b\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0442\u0440\u0438\u043b\u043b\u0435\u0440, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u043d\u0435 \u043e\u0441\u0442\u0430\u0432\u0438\u0442 \u0440\u0430\u0432\u043d\u043e\u0434\u0443\u0448\u043d\u044b\u043c. <\/p>\n<p>\u0412\u044b\u0431\u043e\u0440 \u0444\u0438\u043b\u044c\u043c\u0430 \u0437\u0430\u0432\u0438\u0441\u0438\u0442 \u043e\u0442 \u0432\u0430\u0448\u0435\u0433\u043e \u043d\u0430\u0441\u0442\u0440\u043e\u0435\u043d\u0438\u044f \u0438 \u0442\u043e\u0433\u043e, \u0441 \u043a\u0435\u043c \u0432\u044b \u043f\u043b\u0430\u043d\u0438\u0440\u0443\u0435\u0442\u0435 \u043f\u0440\u043e\u0432\u0435\u0441\u0442\u0438 \u0432\u0435\u0447\u0435\u0440. \u0412\u0430\u0436\u043d\u043e \u0443\u0447\u0438\u0442\u044b\u0432\u0430\u0442\u044c \u0438\u043d\u0442\u0435\u0440\u0435\u0441\u044b \u0437\u0440\u0438\u0442\u0435\u043b\u0435\u0439, \u0447\u0442\u043e\u0431\u044b \u0432\u0441\u0435 \u043f\u043e\u043b\u0443\u0447\u0438\u043b\u0438 \u0443\u0434\u043e\u0432\u043e\u043b\u044c\u0441\u0442\u0432\u0438\u0435 \u043e\u0442 \u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440\u0430.<\/p>\n<p>\u041d\u0435 \u0437\u0430\u0431\u044b\u0432\u0430\u0439\u0442\u0435 \u043f\u0440\u043e \u0440\u0430\u0437\u043b\u0438\u0447\u043d\u044b\u0435 \u0441\u0442\u0440\u0438\u043c\u0438\u043d\u0433\u043e\u0432\u044b\u0435 \u0441\u0435\u0440\u0432\u0438\u0441\u044b, \u0433\u0434\u0435 \u043c\u043e\u0436\u043d\u043e \u043d\u0430\u0439\u0442\u0438 \u043a\u0430\u043a \u043d\u043e\u0432\u0438\u043d\u043a\u0438, \u0442\u0430\u043a \u0438 \u043a\u043b\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u0444\u0438\u043b\u044c\u043c\u044b. \u0413\u043b\u0430\u0432\u043d\u043e\u0435 \u2013 \u044d\u0442\u043e \u0441\u043e\u0437\u0434\u0430\u0442\u044c \u0430\u0442\u043c\u043e\u0441\u0444\u0435\u0440\u0443, \u043f\u043e\u0434\u0445\u043e\u0434\u044f\u0449\u0443\u044e \u0434\u043b\u044f \u043a\u0438\u043d\u043e\u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440\u0430: \u043f\u0440\u0438\u0433\u043e\u0442\u043e\u0432\u044c\u0442\u0435 \u043f\u043e\u043f\u043a\u043e\u0440\u043d, \u043d\u0430\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u0439\u0442\u0435\u0441\u044c \u043d\u0430 \u043f\u043e\u0437\u0438\u0442\u0438\u0432 \u0438 \u0432\u044b\u0431\u0438\u0440\u0430\u0439\u0442\u0435 \u043b\u0443\u0447\u0448\u0443\u044e \u043b\u0435\u043d\u0442\u0443 \u0434\u043b\u044f \u0432\u0435\u0447\u0435\u0440\u0430!<\/p>\n<h2>\u0420\u0430\u0437\u0432\u043b\u0435\u043a\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u0435 \u0448\u043e\u0443 \u0438 \u0440\u0435\u0430\u043b\u0438\u0442\u0438: \u0447\u0442\u043e \u0441\u0442\u043e\u0438\u0442 \u0443\u0432\u0438\u0434\u0435\u0442\u044c?<\/h2>\n<p>\u0415\u0441\u043b\u0438 \u0432\u044b \u0438\u0449\u0435\u0442\u0435, \u0447\u0435\u043c \u0437\u0430\u043d\u044f\u0442\u044c \u0441\u0432\u043e\u0435 \u0432\u0435\u0447\u0435\u0440\u043d\u0435\u0435 \u0432\u0440\u0435\u043c\u044f, \u043e\u0431\u0440\u0430\u0442\u0438\u0442\u0435 \u0432\u043d\u0438\u043c\u0430\u043d\u0438\u0435 \u043d\u0430 \u0440\u0430\u0437\u0432\u043b\u0435\u043a\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u0435 \u0448\u043e\u0443 \u0438 \u0440\u0435\u0430\u043b\u0438\u0442\u0438-\u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u044b. \u041e\u043d\u0438 \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u044e\u0442 \u0443\u043d\u0438\u043a\u0430\u043b\u044c\u043d\u043e\u0435 \u0441\u043e\u0447\u0435\u0442\u0430\u043d\u0438\u0435 \u044e\u043c\u043e\u0440\u0430, \u0434\u0440\u0430\u043c\u044b \u0438 \u0442\u0432\u043e\u0440\u0447\u0435\u0441\u0442\u0432\u0430, \u043f\u0440\u0438\u0433\u043b\u0430\u0448\u0430\u044f \u0437\u0440\u0438\u0442\u0435\u043b\u0435\u0439 \u0432 \u043c\u0438\u0440 \u043d\u0430\u0441\u0442\u043e\u044f\u0449\u0438\u0445 \u044d\u043c\u043e\u0446\u0438\u0439 \u0438 \u043d\u0435\u043e\u0436\u0438\u0434\u0430\u043d\u043d\u044b\u0445 \u043f\u043e\u0432\u043e\u0440\u043e\u0442\u043e\u0432. \u0417\u0430\u043a\u043b\u044e\u0447\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0439 \u044d\u043f\u0438\u0437\u043e\u0434 \u0448\u043e\u0443 <strong>\u201c\u0413\u043e\u043b\u043e\u0441\u201d<\/strong> \u0432\u0441\u0435\u0433\u0434\u0430 \u0441\u043e\u0437\u0434\u0430\u0435\u0442 \u0431\u043e\u043b\u044c\u0448\u043e\u0435 \u043e\u0436\u0438\u0434\u0430\u043d\u0438\u0435: \u043a\u0442\u043e \u0441\u0442\u0430\u043d\u0435\u0442 \u043f\u043e\u0431\u0435\u0434\u0438\u0442\u0435\u043b\u0435\u043c? \u042d\u0442\u043e\u0442 \u043f\u0440\u043e\u0435\u043a\u0442 \u043f\u0440\u043e\u0434\u043e\u043b\u0436\u0430\u0435\u0442 \u0443\u0434\u0438\u0432\u043b\u044f\u0442\u044c \u0443\u0440\u043e\u0432\u043d\u0435\u043c \u0442\u0430\u043b\u0430\u043d\u0442\u0430 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u043e\u0432.<\/p>\n<p>\u0414\u043b\u044f \u043b\u044e\u0431\u0438\u0442\u0435\u043b\u0435\u0439 \u0437\u0440\u0435\u043b\u0438\u0449\u043d\u044b\u0445 \u0441\u043e\u0441\u0442\u044f\u0437\u0430\u043d\u0438\u0439 \u043f\u043e\u0434\u043e\u0439\u0434\u0443\u0442 \u0440\u0435\u0430\u043b\u0438\u0442\u0438-\u0448\u043e\u0443, \u0442\u0430\u043a\u0438\u0435 \u043a\u0430\u043a <strong>\u201cSurvivor\u201d<\/strong> \u0438\u043b\u0438 <strong>\u201c\u0412 \u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0435\u043c \u043f\u043e\u0435\u0434\u0438\u043d\u043a\u0435\u201d<\/strong>. \u042d\u0442\u0438 \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u044b \u043f\u043e\u0433\u0440\u0443\u0436\u0430\u044e\u0442 \u0432\u0430\u0441 \u0432 \u0430\u0442\u043c\u043e\u0441\u0444\u0435\u0440\u0443 \u0431\u043e\u0440\u044c\u0431\u044b \u0437\u0430 \u0432\u044b\u0436\u0438\u0432\u0430\u043d\u0438\u0435, \u0433\u0434\u0435 \u043a\u0430\u0436\u0434\u044b\u0439 \u044d\u043f\u0438\u0437\u043e\u0434 \u043d\u0430\u043f\u043e\u043b\u043d\u0435\u043d \u043d\u0430\u043f\u0440\u044f\u0436\u0435\u043d\u0438\u0435\u043c \u0438 \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u0447\u0435\u0441\u043a\u0438\u043c\u0438 \u043c\u0430\u043d\u0435\u0432\u0440\u0430\u043c\u0438 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u043e\u0432. \u041d\u0435 \u0437\u0430\u0431\u044b\u0432\u0430\u0439\u0442\u0435, \u0447\u0442\u043e \u0442\u0430\u043a\u0438\u0435 \u0448\u043e\u0443 \u043d\u0435 \u0442\u043e\u043b\u044c\u043a\u043e \u0440\u0430\u0437\u0432\u043b\u0435\u0447\u0435\u043d\u0438\u044f, \u043d\u043e \u0438 \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u0435 \u0447\u0435\u043b\u043e\u0432\u0435\u0447\u0435\u0441\u043a\u043e\u0439 \u043f\u0440\u0438\u0440\u043e\u0434\u044b \u0432 \u044d\u043a\u0441\u0442\u0440\u0435\u043c\u0430\u043b\u044c\u043d\u044b\u0445 \u0443\u0441\u043b\u043e\u0432\u0438\u044f\u0445.<\/p>\n<p>\u0415\u0441\u043b\u0438 \u0432\u044b \u043f\u0440\u0435\u0434\u043f\u043e\u0447\u0438\u0442\u0430\u0435\u0442\u0435 \u0447\u0442\u043