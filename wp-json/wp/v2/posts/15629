43\u0434\u0430\u0440\u0441\u0442\u0432\u0430 \u043f\u043e \u043c\u043e\u0431\u0438\u043b\u0438\u0437\u0430\u0446\u0438\u0438 \u043c\u043e\u043b\u043e\u0434\u0435\u0436\u0438 \u0434\u043b\u044f \u0432\u043e\u0441\u043f\u0438\u0442\u0430\u043d\u0438\u044f \u043d\u0430\u0446\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u043e\u0439 \u0433\u043e\u0440\u0434\u043e\u0441\u0442\u0438 \u0438 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0438. <strong>\u041d\u0430 \u043f\u0440\u043e\u0442\u044f\u0436\u0435\u043d\u0438\u0438 \u0434\u0435\u0441\u044f\u0442\u0438\u043b\u0435\u0442\u0438\u0439 \u00ab\u0421\u0442\u0430\u043b\u0438\u043d\u0441\u043a\u0438\u0435 \u0441\u043e\u043a\u043e\u043b\u044b\u00bb \u043e\u0441\u0442\u0430\u0432\u0430\u043b\u0438\u0441\u044c \u0441\u0438\u043c\u0432\u043e\u043b\u043e\u043c \u0441\u0438\u043b\u044b \u0438 \u0435\u0434\u0438\u043d\u0441\u0442\u0432\u0430, \u043e\u0431\u0443\u0447\u0430\u044f \u043c\u043e\u043b\u043e\u0434\u043e\u0435 \u043f\u043e\u043a\u043e\u043b\u0435\u043d\u0438\u0435 \u043e\u0441\u043d\u043e\u0432\u0430\u043c \u0441\u043f\u043e\u0440\u0442\u0438\u0432\u043d\u043e\u0439 \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438, \u0441\u0442\u0440\u0435\u043b\u044c\u0431\u044b \u0438 \u0432\u043e\u0435\u043d\u043d\u043e\u0439 \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0438.<\/strong><\/p>\n<p>\u0412 \u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u0435 \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u044f \u0434\u0430\u043d\u043d\u043e\u0439 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u0438 \u0432\u0430\u0436\u043d\u043e \u0440\u0430\u0441\u0441\u043c\u043e\u0442\u0440\u0435\u0442\u044c \u0435\u0435 \u0432\u043b\u0438\u044f\u043d\u0438\u0435 \u043d\u0430 \u043e\u0431\u0449\u0435\u0441\u0442\u0432\u043e \u0438 \u043c\u043e\u043b\u043e\u0434\u0435\u0436\u044c \u0442\u043e\u0439 \u044d\u043f\u043e\u0445\u0438. <strong>\u00ab\u0421\u0442\u0430\u043b\u0438\u043d\u0441\u043a\u0438\u0435 \u0441\u043e\u043a\u043e\u043b\u044b\u00bb \u0441\u0442\u0430\u043b\u0438 \u043d\u0435 \u0442\u043e\u043b\u044c\u043a\u043e \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u043e\u043c \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0432\u043e\u0441\u043f\u0438\u0442\u0430\u043d\u0438\u044f, \u043d\u043e \u0438 \u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u043e\u043c \u0444\u043e\u0440\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u0438\u0434\u0435\u043e\u043b\u043e\u0433\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u043e\u0441\u043d\u043e\u0432, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0434\u043e\u043b\u0436\u043d\u044b \u0431\u044b\u043b\u0438 \u0441\u0434\u0435\u043b\u0430\u0442\u044c \u044e\u043d\u043e\u0448\u0435\u0439 \u0438 \u0434\u0435\u0432\u0443\u0448\u0435\u043a \u0432\u0435\u0440\u043d\u044b\u043c\u0438 \u0437\u0430\u0449\u0438\u0442\u043d\u0438\u043a\u0430\u043c\u0438 \u0441\u0432\u043e\u0435\u0433\u043e \u041e\u0442\u0435\u0447\u0435\u0441\u0442\u0432\u0430.<\/strong> \u041e\u0434\u043d\u0430\u043a\u043e \u0432\u043e\u0437\u043d\u0438\u043a\u0430\u0435\u0442 \u0432\u043e\u043f\u0440\u043e\u0441: \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u043b\u0438 \u044d\u0442\u0430 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u044f \u0441\u0435\u0433\u043e\u0434\u043d\u044f, \u0438 \u0432 \u043a\u0430\u043a\u043e\u0439 \u0444\u043e\u0440\u043c\u0435? \u041e\u0442\u0432\u0435\u0442 \u043d\u0430 \u044d\u0442\u043e\u0442 \u0432\u043e\u043f\u0440\u043e\u0441 \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0433\u043b\u0443\u0431\u043e\u043a\u043e\u0433\u043e \u0430\u043d\u0430\u043b\u0438\u0437\u0430 \u043a\u0430\u043a \u0438\u0441\u0442\u043e\u0440\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u043d\u0430\u0441\u043b\u0435\u0434\u0438\u044f, \u0442\u0430\u043a \u0438 \u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u0445 \u0440\u0435\u0430\u043b\u0438\u0439.<\/p>\n<p>\u0421\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u043e\u0435 \u043e\u0431\u0449\u0435\u0441\u0442\u0432\u043e \u043d\u0443\u0436\u0434\u0430\u0435\u0442\u0441\u044f \u0432 \u0442\u0430\u043a\u0438\u0445 \u0441\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u0430\u0445, \u043a\u0430\u043a \u00ab\u0421\u0442\u0430\u043b\u0438\u043d\u0441\u043a\u0438\u0435 \u0441\u043e\u043a\u043e\u043b\u044b\u00bb, \u0434\u043b\u044f \u0444\u043e\u0440\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u0437\u0434\u043e\u0440\u043e\u0432\u043e\u0439 \u0438 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u0438 \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043b\u0435\u043d\u043d\u043e\u0439 \u043c\u043e\u043b\u043e\u0434\u0435\u0436\u0438. <strong>\u0422\u0435\u043c \u043d\u0435 \u043c\u0435\u043d\u0435\u0435, \u0441 \u0443\u0447\u0435\u0442\u043e\u043c \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u0439 \u0432 \u0441\u043e\u0446\u0438\u0430\u043b\u044c\u043d\u043e\u0439 \u0438 \u043f\u043e\u043b\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u0441\u0444\u0435\u0440\u0430\u0445 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u043f\u043e\u043d\u044f\u0442\u044c, \u043a\u0430\u043a\u0443\u044e \u0440\u043e\u043b\u044c \u043c\u043e\u0433\u0443\u0442 \u0441\u044b\u0433\u0440\u0430\u0442\u044c \u0442\u0430\u043a\u0438\u0435 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u0438 \u0432 21 \u0432\u0435\u043a\u0435 \u0438 \u043a\u0430\u043a\u0438\u0435 \u043d\u043e\u0432\u044b\u0435 \u0444\u043e\u0440\u043c\u044b \u043e\u043d\u0438 \u043c\u043e\u0433\u0443\u0442 \u043f\u0440\u0438\u043d\u044f\u0442\u044c.<\/strong><\/p>\n<h2>\u00ab\u0421\u0442\u0430\u043b\u0438\u043d\u0441\u043a\u0438\u0435 \u0441\u043e\u043a\u043e\u043b\u044b\u00bb: \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u044f \u0438 \u0435\u0435 \u0446\u0435\u043b\u0438<\/h2>\n<p><img src=\"\/wp-content\/images\/stalinskie-sokoli-chto-eto-za-organizatsiya-chem-zanimaetsya-i-sushestvuet-l-nrha1djk.jpg\" alt=\"\u00ab\u0441\u0442\u0430\u043b\u0438\u043d\u0441\u043a\u0438\u0435 \u0441\u043e\u043a\u043e\u043b\u044b\u00bb: \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u044f \u0438 \u0435\u0435 \u0446\u0435\u043b\u0438\" class=\"\"\/><\/p>\n<h3>\u041e\u0441\u043d\u043e\u0432\u043d\u044b\u0435 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u044f \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438<\/h3>\n<p><img src=\"\/wp-content\/images\/stalinskie-sokoli-chto-eto-za-organizatsiya-chem-zanimaetsya-i-sushestvuet-l-6460nmyz.jpg\" alt=\"\u043e\u0441\u043d\u043e\u0432\u043d\u044b\u0435 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u044f \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438\" class=\"\"\/><\/p>\n<p>\u00ab\u0421\u0442\u0430\u043b\u0438\u043d\u0441\u043a\u0438\u0435 \u0441\u043e\u043a\u043e\u043b\u044b\u00bb \u0437\u0430\u043d\u0438\u043c\u0430\u043b\u0438\u0441\u044c \u043d\u0435 \u0442\u043e\u043b\u044c\u043a\u043e \u0441\u043f\u043e\u0440\u0442\u0438\u0432\u043d\u044b\u043c\u0438 \u0442\u0440\u0435\u043d\u0438\u0440\u043e\u0432\u043a\u0430\u043c\u0438, \u043d\u043e \u0438 \u043f\u0440\u043e\u0432\u043e\u0434\u0438\u043b\u0438 \u0440\u0430\u0437\u043b\u0438\u0447\u043d\u044b\u0435 \u043c\u0430\u0441\u0441\u043e\u0432\u044b\u0435 \u043c\u0435\u0440\u043e\u043f\u0440\u0438\u044f\u0442\u0438\u044f, \u0442\u0430\u043a\u0438\u0435 \u043a\u0430\u043a \u0441\u043f\u043e\u0440\u0442\u0438\u0432\u043d\u044b\u0435 \u0441\u043e\u0440\u0435\u0432\u043d\u043e\u0432\u0430\u043d\u0438\u044f, \u043f\u0430\u0440\u0430\u0434\u044b \u0438 \u043a\u0443\u043b\u044c\u0442\u0443\u0440\u043d\u044b\u0435 \u043c\u0435\u0440\u043e\u043f\u0440\u0438\u044f\u0442\u0438\u044f. \u0412\u0430\u0436\u043d\u044b\u043c \u0430\u0441\u043f\u0435\u043a\u0442\u043e\u043c \u0438\u0445 \u0440\u0430\u0431\u043e\u0442\u044b \u0431\u044b\u043b\u043e \u0432\u043e\u0432\u043b\u0435\u0447\u0435\u043d\u0438\u0435 \u043f\u043e\u0434\u0440\u043e\u0441\u0442\u043a\u043e\u0432 \u0432 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u0443\u044e \u043a\u0443\u043b\u044c\u0442\u0443\u0440\u0443 \u0438 \u0441\u043f\u043e\u0440\u0442, \u0447\u0442\u043e \u0441\u043f\u043e\u0441\u043e\u0431\u0441\u0442\u0432\u043e\u0432\u0430\u043b\u043e \u0444\u043e\u0440\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044e \u0437\u0434\u043e\u0440\u043e\u0432\u043e\u0433\u043e \u043e\u0431\u0440\u0430\u0437\u0430 \u0436\u0438\u0437\u043d\u0438. \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u043d\u044b\u0435 \u0437\u0430\u043d\u044f\u0442\u0438\u044f \u0442\u0430\u043a\u0436\u0435 \u0432\u043a\u043b\u044e\u0447\u0430\u043b\u0438 \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u0435 \u0442\u0435\u0445\u043d\u0438\u043a\u0435 \u0440\u0430\u0437\u043b\u0438\u0447\u043d\u044b\u0445 \u0432\u0438\u0434\u043e\u0432 \u0441\u043f\u043e\u0440\u0442\u0430, \u0433\u0438\u043c\u043d\u0430\u0441\u0442\u0438\u043a\u0435 \u0438 \u0432\u043e\u0435\u043d\u043d\u043e\u043c\u0443 \u0434\u0435\u043b\u0443.<\/p>\n<p>\u041e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u044f \u0430\u043a\u0442\u0438\u0432\u043d\u043e \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043b\u0430 \u0438\u0434\u0435\u043e\u043b\u043e\u0433\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u043f\u0440\u0438\u043d\u0446\u0438\u043f\u044b, \u0445\u0430\u0440\u0430\u043a\u0442\u0435\u0440\u043d\u044b\u0435 \u0434\u043b\u044f \u0441\u0442\u0430\u043b\u0438\u043d\u0441\u043a\u043e\u0439 \u044d\u043f\u043e\u0445\u0438, \u0432\u043a\u043b\u044e\u0447\u0430\u044f \u043f\u0440\u043e\u043f\u0430\u0433\u0430\u043d\u0434\u0443 \u0433\u0435\u0440\u043e\u0438\u0437\u043c\u0430 \u0438 \u0433\u043e\u0442\u043e\u0432\u043d\u043e\u0441\u0442\u0438 \u043a \u0437\u0430\u0449\u0438\u0442\u0435 \u0420\u043e\u0434\u0438\u043d\u044b. \u042d\u0442\u0438 \u0438\u0434\u0435\u0438 \u0432\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u043b\u0438\u0441\u044c \u0432 \u0441\u0438\u0441\u0442\u0435\u043c\u0443 \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0438 \u043c\u043e\u043b\u043e\u0434\u0435\u0436\u0438, \u0444\u043e\u0440\u043c\u0438\u0440\u0443\u044f \u043d\u0435 \u0442\u043e\u043b\u044c\u043a\u043e \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u043d\u0430\u0432\u044b\u043a\u0438, \u043d\u043e \u0438 \u043c\u0435\u043d\u0442\u0430\u043b\u044c\u043d\u0443\u044e \u043f\u0440\u0435\u0434\u0430\u043d\u043d\u043e\u0441\u0442\u044c \u0441\u0442\u0440\u0430\u043d\u0435.<\/p>\n<h3>\u0421\u0443\u0449\u0435\u0441\u0442\u0432\u043e\u0432\u0430\u043d\u0438\u0435 \u0438 \u0432\u043b\u0438\u044f\u043d\u0438\u0435<\/h3>\n<p><img src=\"\/wp-content\/images\/stalinskie-sokoli-chto-eto-za-organizatsiya-chem-zanimaetsya-i-sushestvuet-l-ndrqrz8f.jpg\" alt=\"\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043e\u0432\u0430\u043d\u0438\u0435 \u0438 \u0432\u043b\u0438\u044f\u043d\u0438\u0435\" class=\"\"\/><\/p>\n<p>\u0421 \u043d\u0430\u0447\u0430\u043b\u043e\u043c \u0412\u0442\u043e\u0440\u043e\u0439 \u043c\u0438\u0440\u043e\u0432\u043e\u0439 \u0432\u043e\u0439\u043d\u044b \u0432\u043b\u0438\u044f\u043d\u0438\u0435 \u0438 \u043f\u043e\u043f\u0443\u043b\u044f\u0440\u043d\u043e\u0441\u0442\u044c \u00ab\u0421\u0442\u0430\u043b\u0438\u043d\u0441\u043a\u0438\u0445 \u0441\u043e\u043a\u043e\u043b\u043e\u0432\u00bb \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0441\u043d\u0438\u0437\u0438\u043b\u0438\u0441\u044c, \u0442\u0430\u043a \u043a\u0430\u043a \u0432\u043d\u0438\u043c\u0430\u043d\u0438\u0435 \u043e\u0431\u0449\u0435\u0441\u0442\u0432\u0430 \u0441\u043e\u0441\u0440\u0435\u0434\u043e\u0442\u043e\u0447\u0438\u043b\u043e\u0441\u044c \u043d\u0430 \u0432\u043e\u0435\u043d\u043d\u044b\u0445 \u043d\u0443\u0436\u0434\u0430\u0445. \u041e\u0434\u043d\u0430\u043a\u043e \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u044f \u043f\u0440\u043e\u0434\u043e\u043b\u0436\u0430\u043b\u0430 \u0434\u0435\u0439\u0441\u0442\u0432\u043e\u0432\u0430\u0442\u044c \u0432 \u0442\u043e\u043c \u0438\u043b\u0438 \u0438\u043d\u043e\u043c \u0432\u0438\u0434\u0435 \u0434\u043e \u0440\u0430\u0441\u043f\u0430\u0434\u0430 \u0421\u043e\u0432\u0435\u0442\u0441\u043a\u043e\u0433\u043e \u0421\u043e\u044e\u0437\u0430. \u0412 90-\u0435 \u0433\u043e\u0434\u044b \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u043e\u043d\u043d\u043e\u0435 \u043f\u043e\u043b\u0435 \u043e \u043d\u0435\u0439 \u0441\u0442\u0430\u043b\u043e \u043c\u0435\u043d\u0435\u0435 \u0437\u0430\u043c\u0435\u0442\u043d\u044b\u043c, \u0438 \u0435\u0451 \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c \u0444\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0438 \u043f\u0440\u0435\u043a\u0440\u0430\u0442\u0438\u043b\u0430\u0441\u044c.<\/p>\n<p>\u0421\u0435\u0433\u043e\u0434\u043d\u044f \u00ab\u0421\u0442\u0430\u043b\u0438\u043d\u0441\u043a\u0438\u0435 \u0441\u043e\u043a\u043e\u043b\u044b\u00bb \u043a\u0430\u043a \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u044f \u043d\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044e\u0442, \u043e\u0434\u043d\u0430\u043a\u043e \u044d\u043b\u0435\u043c\u0435\u043d\u0442\u044b \u0438\u0445 \u0444\u0438\u043b\u043e\u0441\u043e\u0444\u0438\u0438 \u0438 \u043f\u043e\u0434\u0445\u043e\u0434\u043e\u0432 \u043c\u043e\u0436\u043d\u043e \u0443\u0432\u0438\u0434\u0435\u0442\u044c \u0432 \u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u0445 \u0441\u043f\u043e\u0440\u0442\u0438\u0432\u043d\u044b\u0445 \u0438 \u043f\u0430\u0442\u0440\u0438\u043e\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u0434\u0432\u0438\u0436\u0435\u043d\u0438\u044f\u0445, \u043d\u0430\u0446\u0435\u043b\u0435\u043d\u043d\u044b\u0445 \u043d\u0430 \u0432\u043e\u0432\u043b\u0435\u0447\u0435\u043d\u0438\u0435 \u043c\u043e\u043b\u043e\u0434\u0435\u0436\u0438 \u0432 \u0430\u043a\u0442\u0438\u0432\u043d\u044b\u0439 \u043e\u0431\u0440\u0430\u0437 \u0436\u0438\u0437\u043d\u0438. \u0421\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u0430\u044f \u0420\u043e\u0441\u0441\u0438\u044f \u043f\u0440\u043e\u0434\u043e\u043b\u0436\u0430\u0435\u0442 \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u0442\u044c \u0432\u0441\u0435 \u0431\u043e\u043b\u0435\u0435 \u0440\u0430\u0437\u043d\u043e\u043e\u0431\u0440\u0430\u0437\u043d\u044b\u0435 \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u044b \u043f\u043e \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u043a\u0443\u043b\u044c\u0442\u0443\u0440\u0435 \u0438 \u0441\u043f\u043e\u0440\u0442\u0443, \u0432 \u0441\u0442\u0440\u0435\u043c\u043b\u0435\u043d\u0438\u0438 \u0432\u043e\u0441\u043f\u0438\u0442\u0430\u0442\u044c \u0437\u0434\u043e\u0440\u043e\u0432\u043e\u0435 \u0438 \u043f\u0430\u0442\u0440\u0438\u043e\u0442\u0438\u0447\u043d\u043e\u0435 \u043f\u043e\u043a\u043e\u043b\u0435\u043d\u0438\u0435.<\/p>\n<h2>\u0418\u0441\u0442\u043e\u0440\u0438\u044f \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044f \u0438 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u00ab\u0421\u0442\u0430\u043b\u0438\u043d\u0441\u043a\u0438\u0445 \u0441\u043e\u043a\u043e\u043b\u043e\u0432\u00bb<\/h2>\n<h3>\u0421\u043e\u0437\u0434\u0430\u043d\u0438\u0435 \u0438 \u043f\u0435\u0440\u0432\u044b\u0435 \u0448\u0430\u0433\u0438<\/h3>\n<p><img src=\"\/wp-content\/images\/stalinskie-sokoli-chto-eto-za-organizatsiya-chem-zanimaetsya-i-sushestvuet-l-vfj9mdz0.jpg\" alt=\"\u0441\u043e\u0437\u0434\u0430\u043d\u0438\u0435 \u0438 \u043f\u0435\u0440\u0432\u044b\u0435 \u0448\u0430\u0433\u0438\" class=\"\"\/><\/p>\n<p>\u0418\u0434\u0435\u044f \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044f \u00ab\u0421\u0442\u0430\u043b\u0438\u043d\u0441\u043a\u0438\u0445 \u0441\u043e\u043a\u043e\u043b\u043e\u0432\u00bb \u0431\u044b\u043b\u0430 \u043e\u0437\u0432\u0443\u0447\u0435\u043d\u0430 \u0432 1937 \u0433\u043e\u0434\u0443 \u0432\u043e \u0432\u0440\u0435\u043c\u044f \u0443\u0432\u0435\u043b\u0438\u0447\u0435\u043d\u0438\u044f \u0438\u043d\u0442\u0435\u0440\u0435\u0441\u0430 \u043a \u0430\u0432\u0438\u0430\u0446\u0438\u0438. \u0421\u0442\u0430\u0440\u0442\u043e\u043c \u0434\u043b\u044f \u0435\u0435 \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044f \u0441\u0442\u0430\u043b\u043e \u043e\u0431\u0440\u0430\u0449\u0435\u043d\u0438\u0435 \u0418\u043e\u0441\u0438\u0444\u0430 \u0421\u0442\u0430\u043b\u0438\u043d\u0430 \u043a \u0440\u0443\u043a\u043e\u0432\u043e\u0434\u0441\u0442\u0432\u0443 \u0441\u0442\u0440\u0430\u043d\u044b. \u0412 \u0438\u0442\u043e\u0433\u0435, \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u044f \u043d\u0430\u0447\u0430\u043b\u0430 \u0430\u043a\u0442\u0438\u0432\u043d\u043e \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u0442\u044c\u0441\u044f, \u043f\u0440\u0438\u043d\u0438\u043c\u0430\u044f \u0432 \u0441\u0432\u043e\u0438 \u0440\u044f\u0434\u044b \u043c\u043d\u043e\u0436\u0435\u0441\u0442\u0432\u043e \u043f\u043e\u0434\u0440\u043e\u0441\u0442\u043a\u043e\u0432 \u0438 \u043c\u043e\u043b\u043e\u0434\u0435\u0436\u0438.<\/p>\n<ul> \u041a\u0430\u043a \u0447\u0430\u0441\u0442\u044c \u043a\u043e\u043c\u0441\u043e\u043c\u043e\u043b\u0430, \u00ab\u0421\u0442\u0430\u043b\u0438\u043d\u0441\u043a\u0438\u0435 \u0441\u043e\u043a\u043e\u043b\u044b\u00bb \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u043e\u0432\u0430\u043b\u0438 \u043a\u0443\u0440\u0441\u044b \u043f\u043e \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044e \u043f\u0438\u043b\u043e\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044e. \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u043e\u0432\u0430\u043b\u0430 \u0441\u0435\u0442\u044c \u043a\u0440\u0443\u0436\u043a\u043e\u0432, \u0433\u0434\u0435 \u044e\u043d\u044b\u0435 \u0430\u0432\u0438\u0430\u0442\u043e\u0440\u044b \u0438\u0437\u0443\u0447\u0430\u043b\u0438 \u0442\u0435\u043e\u0440\u0438\u044e \u0438 \u043f\u0440\u0430\u043a\u0442\u0438\u043a\u0443 \u0430\u0432\u0438\u0430\u0446\u0438\u0438. \u0421\u0440\u0435\u0434\u0438 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u043e\u0432 \u043f\u0440\u043e\u0432\u043e\u0434\u0438\u043b\u0438\u0441\u044c \u0441\u043e\u0440\u0435\u0432\u043d\u043e\u0432\u0430\u043d\u0438\u044f, \u0447\u0442\u043e \u0441\u043f\u043e\u0441\u043e\u0431\u0441\u0442\u0432\u043e\u0432\u0430\u043b\u043e \u043f\u043e\u0432\u044b\u0448\u0435\u043d\u0438\u044e \u0438\u043d\u0442\u0435\u0440\u0435\u0441\u0430 \u043a \u0430\u0432\u0438\u0430\u0446\u0438\u0438. <\/ul>\n<h3>\u0420\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0438 \u043f\u043e\u043f\u0443\u043b\u044f\u0440\u043d\u043e\u0441\u0442\u044c<\/h3>\n<p>\u0421 \u0440\u043e\u0441\u0442\u043e\u043c \u043f\u043e\u043f\u0443\u043b\u044f\u0440\u043d\u043e\u0441\u0442\u0438 \u0430\u0432\u0438\u0430\u0446\u0438\u0438 \u0432 \u0441\u0442\u0440\u0430\u043d\u0435 \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u0447\u043b\u0435\u043d\u043e\u0432 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u0438 \u0443\u0432\u0435\u043b\u0438\u0447\u0438\u0432\u0430\u043b\u043e\u0441\u044c. \u041a \u043d\u0430\u0447\u0430\u043b\u0443 1940-\u0445 \u0433\u043e\u0434\u043e\u0432 \u0447\u0438\u0441\u043b\u0435\u043d\u043d\u043e\u0441\u0442\u044c \u00ab\u0421\u0442\u0430\u043b\u0438\u043d\u0441\u043a\u0438\u0445 \u0441\u043e\u043a\u043e\u043b\u043e\u0432\u00bb \u0434\u043e\u0441\u0442\u0438\u0433\u043b\u0430 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u0438\u0445 \u0441\u043e\u0442\u0435\u043d \u0442\u044b\u0441\u044f\u0447. \u042d\u0442\u043e \u0441\u043f\u043e\u0441\u043e\u0431\u0441\u0442\u0432\u043e\u0432\u0430\u043b\u043e \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0435 \u0437\u043d\u0430\u0447\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0433\u043e \u0447\u0438\u0441\u043b\u0430 \u0431\u0443\u0434\u0443\u0449\u0438\u0445 \u043b\u0435\u0442\u0447\u0438\u043a\u043e\u0432 \u0438 \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u0438\u0441\u0442\u043e\u0432.<\/p>\n<p>\u0412\u043e \u0432\u0440\u0435\u043c\u044f \u0412\u0442\u043e\u0440\u043e\u0439 \u043c\u0438\u0440\u043e\u0432\u043e\u0439 \u0432\u043e\u0439\u043d\u044b \u043c\u043d\u043e\u0433\u0438\u0435 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u0438 \u00ab\u0421\u0442\u0430\u043b\u0438\u043d\u0441\u043a\u0438\u0445 \u0441\u043e\u043a\u043e\u043b\u043e\u0432\u00bb \u043e\u0442\u043f\u0440\u0430\u0432\u0438\u043b\u0438\u0441\u044c \u043d\u0430 \u0444\u0440\u043e\u043d\u0442, \u043f\u0440\u043e\u0434\u043e\u043b\u0436\u0430\u044f \u0441\u043b\u0443\u0436\u0438\u0442\u044c \u0432 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0435 \u043f\u0438\u043b\u043e\u0442\u043e\u0432 \u0438 \u0438\u043d\u0436\u0435\u043d\u0435\u0440\u043e\u0432. \u0414\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u0438 \u0437\u043d\u0430\u0447\u0438\u0442\u0435\u043b\u044c\u043d\u043e \u0443\u0441\u0438\u043b\u0438\u043b\u0430\u0441\u044c \u0432 \u044d\u0442\u0438 \u0442\u0440\u0443\u0434\u043d\u044b\u0435 \u0432\u0440\u0435\u043c\u0435\u043d\u0430, \u043f\u043e\u0441\u043a\u043e\u043b\u044c\u043a\u0443 \u043a \u043d\u0435\u0439 \u043f\u0440\u0438\u0441\u043e\u0435\u0434\u0438\u043d\u0438\u043b\u0438\u0441\u044c \u043d\u043e\u0432\u0438\u0447\u043a\u0438, \u0436\u0435\u043b\u0430\u044e\u0449\u0438\u0435 \u0432\u043d\u0435\u0441\u0442\u0438 \u0441\u0432\u043e\u0439 \u0432\u043a\u043b\u0430\u0434 \u0432 \u0437\u0430\u0449\u0438\u0442\u0443 \u0441\u0442\u0440\u0430\u043d\u044b.<\/p>\n<p>\u041f\u043e\u0441\u043b\u0435 \u0432\u043e\u0439\u043d\u044b \u00ab\u0421\u0442\u0430\u043b\u0438\u043d\u0441\u043a\u0438\u0435 \u0441\u043e\u043a\u043e\u043b\u044b\u00bb \u043f\u0440\u043e\u0434\u043e\u043b\u0436\u0430\u043b\u0438 \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0438\u0440\u043e\u0432\u0430\u0442\u044c, \u043d\u043e \u0441\u043e \u0432\u0440\u0435\u043c\u0435\u043d\u0435\u043c \u0438\u0445 \u0440\u043e\u043b\u044c \u0438 \u0432\u043b\u0438\u044f\u043d\u0438\u0435 \u043d\u0430\u0447\u0430\u043b\u0438 \u0441\u043d\u0438\u0436\u0430\u0442\u044c\u0441\u044f. \u0412 1950-\u0435 \u0433\u043e\u0434\u044b, \u0441 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u0435\u043c \u043f\u043e\u043b\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u0430 \u0438 \u0443\u043c\u0435\u043d\u044c\u0448\u0435\u043d\u0438\u0435\u043c \u043c\u0438\u043b\u0438\u0442\u0430\u0440\u0438\u0437\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u043e\u0433\u043e \u0432\u043e\u0441\u043f\u0438\u0442\u0430\u043d\u0438\u044f, \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u044f \u0442\u0435\u0440\u044f\u043b\u0430 \u0441\u0432\u043e\u0438 \u043f\u043e\u0437\u0438\u0446\u0438\u0438.<\/p>\n<p>\u041d\u0430 \u0441\u0435\u0433\u043e\u0434\u043d\u044f\u0448\u043d\u0438\u0439 \u0434\u0435\u043d\u044c \u00ab\u0421\u0442\u0430\u043b\u0438\u043d\u0441\u043a\u0438\u0435 \u0441\u043e\u043a\u043e\u043b\u044b\u00bb \u043a\u0430\u043a \u0441\u0430\u043c\u043e\u0441\u0442\u043e\u044f\u0442\u0435\u043b\u044c\u043d\u0430\u044f \u0441\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u0430 \u0431\u043e\u043b\u044c\u0448\u0435 \u043d\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442, \u043d\u043e \u0438\u0445 \u043d\u0430\u0441\u043b\u0435\u0434\u0438\u0435 \u043f\u0440\u043e\u0434\u043e\u043b\u0436\u0430\u0435\u0442 \u0436\u0438\u0442\u044c \u0432 \u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u0445 \u043c\u043e\u043b\u043e\u0434\u0435\u0436\u043d\u044b\u0445 \u0430\u0432\u0438\u0430\u043c\u043e\u0434\u0435\u043b\u044c\u043d\u044b\u0445 \u043a\u043b\u0443\u0431\u0430\u0445 \u0438 \u0441\u043f\u043e\u0440\u0442\u0438\u0432\u043d\u044b\u0445 \u0441\u0435\u043a\u0446\u0438\u044f\u0445. \u0418\u043d\u0442\u0435\u0440\u0435\u0441 \u043a \u0430\u0432\u0438\u0430\u0446\u0438\u0438 \u0441\u0440\u0435\u0434\u0438 \u043c\u043e\u043b\u043e\u0434\u0435\u0436\u0438 \u043f\u043e-\u043f\u0440\u0435\u0436\u043d\u0435\u043c\u0443 \u0430\u043a\u0442\u0443\u0430\u043b\u0435\u043d, \u0438 \u0432 \u044d\u0442\u043e\u043c \u043e\u0442\u043d\u043e\u0448\u0435\u043d\u0438\u0438 \u043c\u043e\u0436\u043d\u043e \u043d\u0430\u0431\u043b\u044e\u0434\u0430\u0442\u044c \u043d\u0435\u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u0430\u0440\u0430\u043b\u043b\u0435\u043b\u0438 \u0441 \u0438\u0441\u0442\u043e\u0440\u0438\u0447\u0435\u0441\u043a\u0438\u043c \u043e\u043f\u044b\u0442\u043e\u043c \u00ab\u0421\u0442\u0430\u043b\u0438\u043d\u0441\u043a\u0438\u0445 \u0441\u043e\u043a\u043e\u043b\u043e\u0432\u00bb.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u00ab\u0421\u0442\u0430\u043b\u0438\u043d\u0441\u043a\u0438\u0435 \u0441\u043e\u043a\u043e\u043b\u044b\u00bb \u2013 \u044d\u0442\u043e \u0438\u0441\u0442\u043e\u0440\u0438\u044f, \u043f\u0440\u043e\u043f\u0438\u0442\u0430\u043d\u043d\u0430\u044f \u0434\u0443\u0445\u043e\u043c \u043f\u0430\u0442\u0440\u0438\u043e\u0442\u0438\u0437\u043c\u0430 \u0438 \u0438\u0434\u0435\u043e\u043b\u043e\u0433\u0438\u0438, \u043a\u043e\u0442\u043e\u0440\u0430\u044f \u0444\u043e\u0440\u043c\u0438\u0440\u043e\u0432\u0430\u043b\u0430\u0441\u044c \u0432 \u0421\u043e\u0432\u0435\u0442\u0441\u043a\u043e\u043c \u0421\u043e\u044e\u0437\u0435 \u0432 \u044d\u043f\u043e\u0445\u0443 \u0421\u0442\u0430\u043b\u0438\u043d\u0430. \u042d\u0442\u0430 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u044f \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043b\u044f\u043b\u0430 \u0441\u043e\u0431\u043e\u0439 \u0443\u0441\u0438\u043b\u0438\u044f \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0430 \u043f\u043e \u043c\u043e\u0431\u0438\u043b\u0438\u0437\u0430\u0446\u0438\u0438 \u043c\u043e\u043b\u043e\u0434\u0435\u0436\u0438 \u0434\u043b\u044f \u0432\u043e\u0441\u043f\u0438\u0442\u0430\u043d\u0438\u044f \u043d\u0430\u0446\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u043